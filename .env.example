# Backend the MCP server talks to. Any backend implementing spec/tools.json
# works here — this doesn't have to be Aluseg's hosted instance.
ALUSEG_BACKEND_URL=https://your-backend.example.com

# OAuth 2.0 client used to validate per-user tokens presented by the AI
# client. Never a shared/master credential — see src/security/oauth.ts.
OAUTH_ISSUER_URL=https://your-backend.example.com/oauth
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=

# Append-only sink for audit log entries (e.g. a WORM-configured table or
# object store). See src/security/auditLog.ts.
AUDIT_LOG_SINK=
